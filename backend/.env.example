# 🏠 HomeSetup Luxembourg — Backend Environment Variables
# Copiar este archivo como .env y rellenar los valores reales
# NUNCA subir .env a Git (ya está en .gitignore)

# ════════════════════════════════════════════
# 🗄️  SUPABASE (Base de datos)
# Obtener en: supabase.com → Settings → API
# ════════════════════════════════════════════
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...tu-service-role-key

# ════════════════════════════════════════════
# 📬 RESEND (Email transaccional)
# Obtener en: resend.com → API Keys
# ════════════════════════════════════════════
RESEND_API_KEY=re_...tu-resend-api-key

# ════════════════════════════════════════════
# 🔒 WEBHOOKS (Artisan Furniture EU)
# Generar: openssl rand -hex 32
# ════════════════════════════════════════════
ARTISAN_WEBHOOK_SECRET=genera-un-secreto-largo-aqui

# ════════════════════════════════════════════
# 🌐 SERVIDOR
# ════════════════════════════════════════════
PORT=3000
NODE_ENV=development
