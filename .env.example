# 🏠 HomeSetup Luxembourg — Frontend Environment Variables
# Copiar como .env.local (nunca subir a Git)

# Gemini API Key para El Conserje chatbot
# Obtener en: aistudio.google.com/app/apikey (gratis con cuenta Google)
VITE_GEMINI_API_KEY=AIza...tu-gemini-api-key

# Backend API URL (cambiar a Cloudflare Workers URL cuando esté deployado)
VITE_API_URL=http://localhost:3000

# Stripe Public Key (Empieza con pk_)
VITE_STRIPE_PUBLIC_KEY=pk_test_...
